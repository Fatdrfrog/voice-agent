# Copy to .env and fill in values.
OPENAI_API_KEY=<OPENAI_API_KEY>

ELEVENLABS_API_KEY=<ELEVENLABS_API_KEY>
ELEVENLABS_VOICE_ID=<ELEVENLABS_VOICE_ID>
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32
ELEVENLABS_VOICE_SPEED=1.05
ELEVENLABS_SCRIBE_MODEL_ID=scribe_v2_realtime
ELEVENLABS_SCRIBE_WS_URL=wss://api.elevenlabs.io/v1/speech-to-text/realtime
ELEVENLABS_SCRIBE_LANGUAGE_CODE=en
ELEVENLABS_SCRIBE_INCLUDE_TIMESTAMPS=true
ELEVENLABS_SCRIBE_INCLUDE_LANGUAGE_DETECTION=true
ELEVENLABS_SCRIBE_AUDIO_FORMAT=pcm_24000
ELEVENLABS_SCRIBE_COMMIT_STRATEGY=vad
ELEVENLABS_SCRIBE_VAD_SILENCE_THRESHOLD_SECS=0.45
ELEVENLABS_SCRIBE_VAD_THRESHOLD=0.4
ELEVENLABS_SCRIBE_MIN_SPEECH_DURATION_MS=80
ELEVENLABS_SCRIBE_MIN_SILENCE_DURATION_MS=80

OPENCLAW_BINARY=openclaw
OPENCLAW_WSL_DISTRO=
OPENCLAW_GATEWAY_URL=<OPENCLAW_GATEWAY_URL>
OPENCLAW_GATEWAY_TOKEN=<OPENCLAW_GATEWAY_TOKEN>

VOICE_DEV_AGENT_WORKSPACES=./config/workspaces.json
VOICE_DEV_AGENT_MIC_MODE=true
VOICE_DEV_AGENT_CALL_MODE=false
VOICE_DEV_AGENT_AUTO_EXEC_GUARDED=true
VOICE_DEV_AGENT_STT_PROVIDER=elevenlabs-scribe
